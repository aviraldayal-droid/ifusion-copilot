# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=197.230.47.51
DB_PORT=5432
DB_USER=digiwise_rw
DB_PASSWORD=
DB_NAME=digiwise

# ── Ollama (Cloud) ───────────────────────────────────────────────────────────
# For Ollama Cloud: set OLLAMA_BASE_URL=https://api.ollama.com and your API key
OLLAMA_BASE_URL=https://api.ollama.com
OLLAMA_MODEL=qwen3-coder:480b
OLLAMA_API_KEY=

# Narration model for format_answer (fluent language model recommended)
OLLAMA_NARRATION_MODEL=ministral-3:14b

# ── Ollama (Local) ───────────────────────────────────────────────────────────
# For local Ollama: set OLLAMA_BASE_URL=http://ollama:11434 (Docker) or
# http://localhost:11434 (host), and leave OLLAMA_API_KEY empty.
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_API_KEY=

# Optional dedicated embedding model (falls back to OLLAMA_MODEL if empty)
OLLAMA_EMBEDDING_MODEL=

# ── LangSmith tracing (optional) ────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=tbg-ai-copilot
LANGCHAIN_TRACING_V2=true
